‚Äé</style>
‚Äé</head>
‚Äé
‚Äé<body>
‚Äé
‚Äé<canvas id="canvas"></canvas>
‚Äé
‚Äé<script>
‚Äé
‚Äéconst canvas = document.getElementById("canvas");
‚Äéconst ctx = canvas.getContext("2d");
‚Äé
‚Äécanvas.width = window.innerWidth;
