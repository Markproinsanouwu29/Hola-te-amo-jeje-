‚Äé
‚Äélet particles = [];
‚Äé
‚Äéfunction heartShape(t){
‚Äéreturn {
‚Äéx:16*Math.pow(Math.sin(t),3),
‚Äéy:-(13*Math.cos(t)-5*Math.cos(2*t)-2*Math.cos(3*t)-Math.cos(4*t))
‚Äé};
‚Äé}
‚Äé
‚Äéfor(let i=0;i<800;i++){
‚Äé
‚Äélet t=Math.random()*Math.PI*2;
‚Äélet pos=heartShape(t);
‚Äé
‚Äéparticles.push({
‚Äéx:Math.random()*canvas.width,
‚Äéy:Math.random()*canvas.height,
‚Äétx:canvas.width/2+pos.x*20,
‚Äéty:canvas.height/2+pos.y*20
‚Äé});
‚Äé
‚Äé}
‚Äé
‚Äélet phase = 0;
‚Äé
‚ÄésetTimeout(()=>{phase=1},4000);
‚Äé
‚Äéfunction createTextPoints(text){
‚Äé
‚Äélet temp=document.createElement("canvas");
‚Äélet tctx=temp.getContext("2d");
‚Äé
‚Äétemp.width=canvas.width;
‚Äétemp.height=canvas.height;
‚Äé
‚Äétctx.fillStyle="white";
‚Äétctx.font="bold 90px Arial";
‚Äétctx.textAlign="center";
‚Äétctx.fillText(text,canvas.width/2,canvas.height/2);
‚Äé
‚Äélet data=tctx.getImageData(0,0,canvas.width,canvas.height).data;
‚Äé
‚Äélet points=[];
‚Äé
‚Äéfor(let y=0;y<canvas.height;y+=6){
‚Äéfor(let x=0;x<canvas.width;x+=6){
‚Äé
‚Äélet i=(y*canvas.width+x)*4;
‚Äé
‚Äéif(data[i+3]>128){
‚Äépoints.push({x,y});
‚Äé}
‚Äé
‚Äé}
‚Äé}
‚Äé
‚Äéreturn points;
‚Äé
‚Äé}
‚Äé
‚Äélet textPoints=createTextPoints("te amo jeje ");
‚Äé
‚Äéfunction animate(){
‚Äé
‚Äéctx.fillStyle="rgba(0,0,0,0.25)";
‚Äéctx.fillRect(0,0,canvas.width,canvas.height);
‚Äé
‚Äéctx.fillStyle="#ff4da6";
‚Äé
‚Äéparticles.forEach((p,i)=>{
‚Äé
‚Äéif(phase===1 && textPoints[i]){
‚Äép.tx=textPoints[i].x;
‚Äép.ty=textPoints[i].y;
‚Äé}
‚Äé
‚Äép.x += (p.tx-p.x)*0.04;
‚Äép.y += (p.ty-p.y)*0.04;
‚Äé
‚Äéctx.beginPath();
‚Äéctx.arc(p.x,p.y,2,0,Math.PI*2);
‚Äéctx.fill();
‚Äé
‚Äé});
‚Äé
‚ÄérequestAnimationFrame(animate);
‚Äé
‚Äé}
‚Äé
‚Äéanimate();
‚Äé
‚Äé</script>
